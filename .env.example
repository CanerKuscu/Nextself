# BioSync Environment Variables Template
# Copy this file to .env and fill in your actual values

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# AI Configuration
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Spotify Configuration
SPOTIFY_CLIENT_ID=your-spotify-client-id-here
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret-here
SPOTIFY_REDIRECT_URI=your-redirect-uri-here

# App Configuration
APP_NAME=BioSync
APP_ENV=development
APP_VERSION=1.0.0
API_BASE_URL=https://api.biosync.com

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_API_KEY=your-analytics-key-here

# Notifications
NOTIFICATION_ENABLED=true
FCM_SERVER_KEY=your-fcm-server-key-here

# Debug
DEBUG_MODE=true
LOG_LEVEL=debug
NODE_ENV=development

# Expo Public Variables (for React Native)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
EXPO_PUBLIC_DEEPSEEK_API_KEY=your-deepseek-api-key-here
# Encryption key for client-side encryption (must be 32 bytes)
EXPO_PUBLIC_ENCRYPTION_KEY=your_encryption_key_32_bytes
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn-here
# Edge Function (optional override)
EXPO_PUBLIC_SESSION_EXCHANGE_URL=https://your-project.functions.supabase.co/session-exchange
SESSION_EXCHANGE_URL=https://your-project.functions.supabase.co/session-exchange