{
  "expo": {
    "name": "BioSync",
    "slug": "biosync",
    "version": "1.0.1",
    "buildNumber": "2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#050814"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.biosync.app",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Access to Health data is used to provide personalized fitness insights.",
        "NSHealthUpdateUsageDescription": "Access to Health data is used to track workouts and nutrition.",
        "NSCameraUsageDescription": "Camera access is required to scan food barcodes and take profile photos.",
        "NSPhotoLibraryUsageDescription": "Photo library access is required to select profile photos and share progress images."
      }
    },
    "android": {
      "versionCode": 2,
      "predictiveBackGestureEnabled": false,
      "package": "com.biosync.app",
      "permissions": [
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_WEIGHT",
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "biosync",
          "organization": "kuscu"
        }
      ],
      "react-native-health",
      "react-native-health-connect",
      "@sentry/react-native",
      "expo-secure-store",
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "f3e82132-b0a8-4a38-bab8-dc42b16c0af2"
      }
    },
    "owner": "lca.nerl",
    "scheme": "biosync"
  }
}