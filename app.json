{
  "expo": {
    "name": "NextSelf",
    "slug": "nextself",
    "scheme": "nextself",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#050814"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nextself.app",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Access to Health data is used to provide personalized fitness insights.",
        "NSHealthUpdateUsageDescription": "Access to Health data is used to track workouts and nutrition.",
        "NSCameraUsageDescription": "Allow NextSelf to access your camera for on-device posture landmark extraction.",
        "NSPhotoLibraryUsageDescription": "Photo library access is required to select profile photos and share progress images."
      }
    },
    "android": {
      "versionCode": 2,
      "predictiveBackGestureEnabled": true,
      "package": "com.nextself.app",
      "permissions": [
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_WEIGHT",
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "packagingOptions": {
              "pickFirst": ["lib/*/libNitroModules.so"]
            }
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "nextself",
          "organization": "kuscu"
        }
      ],
      "react-native-health",
      "react-native-health-connect",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Allow NextSelf to access your camera for on-device posture landmark extraction."
        }
      ],
      "@sentry/react-native",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1CB0F6"
        }
      ],
      "expo-secure-store",
      "expo-localization",
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow NextSelf to access your calendar to sync workouts and events."
        }
      ],
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermissionText": "Allow NextSelf to access your camera for on-device posture landmark extraction."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-0000000000000000~0000000000",
          "iosAppId": "ca-app-pub-0000000000000000~0000000000"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6a3a6c0f-f620-487b-9068-e0c105c5d5b7"
      }
    },
    "owner": "lca.nerl",
    "scheme": "nextself"
  }
}