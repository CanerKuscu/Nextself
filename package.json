{
  "name": "nextself",
  "version": "1.0.1",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --host lan",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:strict": "eslint . --max-warnings 0",
    "scan:secrets": "node tools/scan-secrets.js",
    "build:dev": "eas build --profile development --platform all",
    "build:preview": "eas build --profile preview --platform all",
    "build:production": "eas build --profile production --platform all",
    "sanitize-dist": "node scripts/sanitize-import-meta.js",
    "postbuild": "npm run sanitize-dist",
    "postinstall": "patch-package",
    "eas:build-and-sanitize": "node scripts/eas-build-and-sanitize.js",
    "e2e:android": "detox test -c android.emu.debug --headless"
  },
  "dependencies": {
    "@nextself/shared": "*",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.15.6",
    "@react-navigation/core": "^7.16.2",
    "@react-navigation/native": "^7.1.34",
    "@react-navigation/native-stack": "^7.14.6",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.45.7",
    "@tanstack/react-query": "^5.95.2",
    "expo": "~54.0.35",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-calendar": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "^18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "^15.0.8",
    "expo-localization": "~17.0.9",
    "expo-notifications": "~0.32.17",
    "expo-secure-store": "~15.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "expo-video-thumbnails": "~10.0.8",
    "i18next": "^25.8.14",
    "lottie-react-native": "^7.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.6",
    "react-native": "0.81.5",
    "react-native-body-highlighter": "^3.1.4",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-google-mobile-ads": "^16.3.1",
    "react-native-health": "^1.19.0",
    "react-native-health-connect": "^3.5.0",
    "react-native-modal": "^13.0.1",
    "react-native-nitro-modules": "^0.29.8",
    "react-native-purchases": "^9.15.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-quick-crypto": "^1.0.18",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-vector-icons": "^10.2.0",
    "react-native-vision-camera": "^4.7.3",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "react-native-worklets-core": "^1.6.2",
    "vision-camera-pose-detector": "^1.1.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/register": "^7.28.6",
    "@eslint/js": "^10.0.1",
    "@testing-library/react-native": "^12.7.2",
    "@types/deno": "^2.5.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.0",
    "@types/react": "~19.1.10",
    "@types/react-test-renderer": "^19.0.8",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "autoprefixer": "^10.4.25",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "detox": "^20.50.1",
    "eslint": "^10.0.2",
    "expo-module-scripts": "^55.0.2",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.6",
    "postinstall-postinstall": "^2.1.0",
    "react-test-renderer": "19.1.0",
    "sharp": "^0.34.5",
    "supabase": "^2.77.0",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ],
    "setupFilesAfterEnv": [],
    "collectCoverageFrom": [
      "**/*.{ts,tsx}",
      "!**/node_modules/**",
      "!**/web/**",
      "!**/android/**",
      "!**/ios/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-health",
          "react-native-vector-icons"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "overrides": {
    "@expo/fingerprint": "0.16.5",
    "esbuild": "0.25.11",
    "picomatch": "4.0.4",
    "yaml": "2.8.3",
    "react-native-health": {
      "@expo/config-plugins": {
        "@expo/fingerprint": "0.16.5"
      }
    }
  },
  "workspaces": [
    "web/dashboard",
    "packages/*"
  ]
}
